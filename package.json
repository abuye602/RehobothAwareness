{
  "name": "elsa-website",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "nodemon -L --watch server.js --watch public --ext js,html,css server.js",
    "dev:sync": "wait-on tcp:3000 && browser-sync start --proxy \"http://localhost:3000\" --files \"public/**/*\" --port 3001 --no-ui --no-open",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:sync\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "body-parser": "^1.20.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "wait-on": "^9.0.4"
  }
}
